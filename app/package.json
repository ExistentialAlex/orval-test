{
  "name": "<project-name>-app",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest --coverage",
    "test:e2e": "bddgen && playwright test",
    "test:e2e:ui": "bddgen & playwright test --ui",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@internationalized/date": "^3.10.1",
    "@nuxt/ui": "4.3.0",
    "@pinia/colada": "0.21.2",
    "@tanstack/vue-table": "8.21.3",
    "@unhead/vue": "2.0.19",
    "@vueuse/core": "14.1.0",
    "defu": "6.1.4",
    "destr": "2.0.5",
    "fast-equals": "6.0.0",
    "ofetch": "1.5.1",
    "pinia": "3.0.4",
    "sortablejs": "^1.15.6",
    "tailwindcss": "4.1.18",
    "<project-name>-i18n": "workspace:^",
    "<project-name>-schemas": "workspace:^",
    "<project-name>-types": "workspace:^",
    "<project-name>-utils": "workspace:^",
    "vue": "3.5.27",
