    "playwright-bdd": "8.4.2",
    "prettier": "3.7.4",
    "<project-name>-eslint-config": "workspace:^",
    "typescript": "~5.9.3",
    "unplugin-vue-router": "0.19.2",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.0.5",
    "vite-plugin-vue-layouts": "0.11.0",
    "vitest": "4.0.17",
